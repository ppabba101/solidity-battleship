# Privy embedded wallet app ID. Obtain from https://dashboard.privy.io/.
# If unset, the app boots the local hot-seat demo instead of the Privy flow.
VITE_PRIVY_APP_ID=

# BattleshipGame contract addresses on Base Sepolia.
# Real deploy uses HonkVerifier, preview deploy uses MockVerifier.
VITE_BATTLESHIP_ADDRESS_REAL=0x0000000000000000000000000000000000000000
VITE_BATTLESHIP_ADDRESS_PREVIEW=0x0000000000000000000000000000000000000000

# Base Sepolia RPC URL (Alchemy/Infura/your own node).
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Set to "1" to boot the legacy hot-seat demo (anvil + burners) bypassing Privy.
# Used by scripts/demo-fast.sh for local development.
VITE_LOCAL_HOTSEAT=0

# Legacy single-address override (local anvil hot-seat path).
VITE_BATTLESHIP_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
